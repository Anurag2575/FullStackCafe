<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>Signup - Full Stack Cafe</title>
</head>
<body class="h-screen flex items-center justify-center bg-amber-50">
    <form action="/auth/signup" method="POST" class="bg-white p-8 rounded-3xl shadow-xl w-96">
        <h2 class="text-2xl font-bold mb-2 text-center text-amber-900">Full Stack Cafe</h2>
        <p class="text-center text-slate-500 mb-6">Join our community</p>
        <% if(error){ %><p class="text-red-500 text-sm mb-4 text-center"><%= error %></p><% } %>
        <input type="text" name="name" placeholder="Full Name" class="w-full p-3 mb-4 border rounded-xl bg-slate-50" required>
        <input type="email" name="email" placeholder="Email" class="w-full p-3 mb-4 border rounded-xl bg-slate-50" required>
        <input type="password" name="password" placeholder="Create Password" class="w-full p-3 mb-4 border rounded-xl bg-slate-50" required>
        <select name="role" class="w-full p-3 mb-6 border rounded-xl bg-slate-50">
            <option value="Student">I am a Student</option>
            <option value="Admin">I am an Admin</option>
        </select>
        <button type="submit" class="w-full bg-amber-900 text-white py-3 rounded-xl font-bold hover:bg-amber-800 transition">Create Account</button>
        
        <div class="mt-6 text-center">
            <a href="/login" class="text-amber-900 font-bold hover:underline">Sign in</a>
        </div>
    </form>
</body>