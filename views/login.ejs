<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>Login - Full Stack Cafe</title>
</head>
<body class="h-screen flex items-center justify-center bg-amber-50">
    <form action="/auth/login" method="POST" class="bg-white p-8 rounded-3xl shadow-xl w-96">
        <h2 class="text-2xl font-bold mb-2 text-center text-amber-900">Full Stack Cafe</h2>
        <p class="text-center text-slate-500 mb-6">Welcome back!</p>
        <% if(error){ %><p class="text-red-500 text-sm mb-4 text-center"><%= error %></p><% } %>
        <input type="email" name="email" placeholder="Email" class="w-full p-3 mb-4 border rounded-xl bg-slate-50" required>
        <input type="password" name="password" placeholder="Password" class="w-full p-3 mb-6 border rounded-xl bg-slate-50" required>
        <button type="submit" class="w-full bg-amber-900 text-white py-3 rounded-xl font-bold hover:bg-amber-800 transition">Sign In</button>
        
        <div class="mt-6 text-center">
            <a href="/signup" class="text-amber-900 font-bold hover:underline">Create one</a>
        </div>
        <div class="mt-4">
            <a href="/" class="block w-full bg-slate-100 text-slate-600 py-3 rounded-xl font-bold text-center hover:bg-slate-200 transition">Return Home</a>
        </div>
    </form>
</body>