<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lato:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <title>My Orders - Full Stack Cafe</title>
    <style>
        h1, h2, h3, h4, .font-serif { font-family: 'Playfair Display', serif; }
        body { font-family: 'Lato', sans-serif; }
        .tab-active { border-bottom: 3px solid #92400e; color: #92400e; }
    </style>
</head>
<body class="bg-[#fafaf9] text-stone-800">
    <!-- Navigation -->
    <nav class="bg-white px-6 py-4 shadow-sm border-b border-stone-200 flex justify-between items-center sticky top-0 z-50">
        <h1 class="text-2xl font-bold text-amber-900 tracking-wider flex items-center gap-2">
            ☕ FULL STACK CAFE
        </h1>
        <div class="space-x-6 flex items-center">
            <a href="/" class="text-stone-600 hover:text-amber-800 transition font-medium">Menu</a>
            <% if (user && user.role === 'Admin') { %>
                <a href="/admin/panel" class="bg-amber-100 text-amber-800 px-4 py-2 rounded-lg font-bold text-sm hover:bg-amber-200 transition">Admin Panel</a>
            <% } %>
            <a href="/dashboard" class="font-bold text-stone-700 hover:text-amber-800">Hi, <%= user.name %></a>
            <a href="/logout" class="text-red-700 font-bold hover:text-red-800 text-sm uppercase tracking-wide">Logout</a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-6">
        <h2 class="text-4xl font-bold mb-8 text-amber-900 border-b-2 border-amber-200 pb-4 inline-block font-serif">My Orders</h2>

        <!-- Tabs -->
        <div class="flex gap-8 border-b border-stone-200 mb-8 mt-8">
            <button class="tab-btn tab-active py-3 px-1 font-bold transition" data-tab="active">
                Active Orders <% if (activeOrders && activeOrders.length > 0) { %>(<%= activeOrders.length %>)<% } %>
            </button>
            <button class="tab-btn py-3 px-1 font-bold text-stone-600 hover:text-amber-800 transition" data-tab="past">
                Past Orders <% if (pastOrders && pastOrders.length > 0) { %>(<%= pastOrders.length %>)<% } %>
            </button>
        </div>

        <!-- Active Orders Tab -->
        <div id="active-tab" class="tab-content">
            <% if (activeOrders && activeOrders.length > 0) { %>
                <div class="space-y-6">
                    <% activeOrders.forEach(order => { %>
                        <div class="bg-white border border-stone-200 rounded-lg shadow-sm hover:shadow-md transition p-6">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h3 class="text-lg font-bold text-stone-800 mb-2">Order #<%= order.id.substring(0, 8).toUpperCase() %></h3>
                                    <p class="text-sm text-stone-500">Placed on <%= new Date(order.createdAt).toLocaleDateString() %> at <%= new Date(order.createdAt).toLocaleTimeString() %></p>
                                </div>
                                <span class="px-4 py-2 rounded-full text-white text-sm font-bold
                                    <% if (order.status === 'Pending') { %>bg-yellow-500<% } %>
                                    <% if (order.status === 'Preparing') { %>bg-blue-500<% } %>
                                    <% if (order.status === 'Completed') { %>bg-purple-500<% } %>
                                    <% if (order.status === 'Delivered') { %>bg-green-500<% } %>
                                ">
                                    <%= order.status %>
                                </span>
                            </div>

                            <div class="border-t border-stone-100 py-4 mb-4">
                                <h4 class="font-bold text-stone-700 mb-3">Items:</h4>
                                <div class="space-y-2">
                                    <% if (order.items && order.items.length > 0) { %>
                                        <% order.items.forEach(item => { %>
                                            <div class="flex justify-between text-sm text-stone-600">
                                                <span><%= item.name %> (x<%= item.quantity %>)</span>
                                                <span class="font-semibold">₹<%= item.price * item.quantity %></span>
                                            </div>
                                        <% }) %>
                                    <% } %>
                                </div>
                            </div>

                            <div class="flex justify-between items-center bg-amber-50 border border-amber-200 rounded-lg p-4">
                                <span class="font-bold text-amber-900">Total Amount:</span>
                                <span class="text-2xl font-bold text-amber-900">₹<%= Number(order.total || 0).toFixed(2) %></span>
                            </div>

                            <% if (order.status === 'Pending') { %>
                                <div class="mt-4 flex items-center gap-2 text-sm text-amber-700 bg-amber-100 p-3 rounded">
                                    <span class="text-lg">⏳</span>
                                    <span>Your order is being prepared. You'll receive an update soon!</span>
                                </div>
                            <% } else if (order.status === 'Preparing') { %>
                                <div class="mt-4 flex items-center gap-2 text-sm text-blue-700 bg-blue-100 p-3 rounded">
                                    <span class="text-lg">👨‍🍳</span>
                                    <span>Your order is being prepared. We're almost done!</span>
                                </div>
                            <% } else if (order.status === 'Completed') { %>
                                <div class="mt-4 flex items-center gap-2 text-sm text-purple-700 bg-purple-100 p-3 rounded">
                                    <span class="text-lg">✅</span>
                                    <span>Your order is completed and ready for pickup!</span>
                                </div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="bg-white p-12 rounded-lg shadow-sm text-center border border-stone-200">
                    <div class="text-6xl mb-4 opacity-30">📦</div>
                    <h3 class="text-xl font-bold mb-2 text-stone-800">No active orders</h3>
                    <p class="text-stone-500 mb-6">You don't have any orders in progress.</p>
                    <a href="/" class="inline-block bg-amber-900 text-white px-6 py-3 rounded-lg font-bold hover:bg-amber-800 transition">
                        Continue Shopping
                    </a>
                </div>
            <% } %>
        </div>

        <!-- Past Orders Tab -->
        <div id="past-tab" class="tab-content hidden">
            <% if (pastOrders && pastOrders.length > 0) { %>
                <div class="space-y-6">
                    <% pastOrders.forEach(order => { %>
                        <div class="bg-white border border-stone-200 rounded-lg shadow-sm hover:shadow-md transition p-6 opacity-90">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h3 class="text-lg font-bold text-stone-800 mb-2">Order #<%= order.id.substring(0, 8).toUpperCase() %></h3>
                                    <p class="text-sm text-stone-500">Placed on <%= new Date(order.createdAt).toLocaleDateString() %></p>
                                </div>
                                <span class="px-4 py-2 rounded-full text-white text-sm font-bold
                                    <% if (order.status === 'Completed') { %>bg-purple-500<% } %>
                                    <% if (order.status === 'Delivered') { %>bg-green-500<% } %>
                                ">
                                    <%= order.status %>
                                </span>
                            </div>

                            <div class="border-t border-stone-100 py-4 mb-4">
                                <h4 class="font-bold text-stone-700 mb-3">Items:</h4>
                                <div class="space-y-2">
                                    <% if (order.items && order.items.length > 0) { %>
                                        <% order.items.forEach(item => { %>
                                            <div class="flex justify-between text-sm text-stone-600">
                                                <span><%= item.name %> (x<%= item.quantity %>)</span>
                                                <span class="font-semibold">₹<%= item.price * item.quantity %></span>
                                            </div>
                                        <% }) %>
                                    <% } %>
                                </div>
                            </div>

                            <div class="flex justify-between items-center bg-stone-100 border border-stone-300 rounded-lg p-4">
                                <span class="font-bold text-stone-700">Total Amount:</span>
                                <span class="text-2xl font-bold text-stone-800">₹<%= Number(order.total || 0).toFixed(2) %></span>
                        </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="bg-white p-12 rounded-lg shadow-sm text-center border border-stone-200">
                    <div class="text-6xl mb-4 opacity-30">🎉</div>
                    <h3 class="text-xl font-bold mb-2 text-stone-800">No past orders</h3>
                    <p class="text-stone-500 mb-6">Once you complete your first order, it will appear here.</p>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        // Tab switching functionality
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const tabName = btn.getAttribute('data-tab');
                
                // Hide all tabs
                document.querySelectorAll('.tab-content').forEach(tab => {
                    tab.classList.add('hidden');
                });
                
                // Remove active class from all buttons
                document.querySelectorAll('.tab-btn').forEach(b => {
                    b.classList.remove('tab-active');
                    b.classList.add('text-stone-600');
                });
                
                // Show selected tab and mark button as active
                document.getElementById(tabName + '-tab').classList.remove('hidden');
                btn.classList.add('tab-active');
                btn.classList.remove('text-stone-600');
            });
        });
    </script>
</body>
</html>
